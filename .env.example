# Database
DATABASE_URL=postgresql://user:password@localhost:5432/dashboard_db

# JWT & Auth
JWT_SECRET=your-super-secret-jwt-key-change-in-production
NEXTAUTH_SECRET=your-nextauth-secret-key
NEXTAUTH_URL=http://localhost:3000

# API URLs
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:3000

# Twilio (WhatsApp)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Gmail API
GMAIL_CLIENT_ID=your_gmail_client_id
GMAIL_CLIENT_SECRET=your_gmail_client_secret
GMAIL_REDIRECT_URI=http://localhost:3000/api/auth/gmail/callback

# n8n
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=your_n8n_api_key
N8N_WEBHOOK_URL=http://localhost:3000/api/n8n/webhook

# Aisensy (WhatsApp Marketing)
AISENSY_API_KEY=your_aisensy_api_key
AISENSY_API_URL=https://api.aisensy.com
AISENSY_WEBHOOK_SECRET=your_aisensy_webhook_secret_key
AISENSY_ENABLE_AUTO_REPLY=true
AISENSY_AUTO_REPLY_TEMPLATE_ID=template_123

# Automation Settings
AUTO_SCORE_ENABLED=true
AUTO_SCORE_INTERVAL_MINUTES=60
AUTO_ENGAGE_MIN_SCORE=70
AUTO_ENGAGE_ENABLED=true

AUTO_FOLLOWUP_ENABLED=true
AUTO_FOLLOWUP_HOURS_THRESHOLD=24
AUTO_FOLLOWUP_INTERVAL_HOURS=4

# AI Response Generation
AI_RESPONSE_ENABLED=true
AI_RESPONSE_CONFIDENCE_THRESHOLD=0.85
